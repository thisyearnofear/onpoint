{
  "name": "onpoint",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "deploy:api": "bash scripts/deploy-api.sh"
  },
  "devDependencies": {
    "@types/minimatch": "3.0.5",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@rainbow-me/rainbowkit": "^2.2.9",
    "@tanstack/react-query": "5.59.20",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0"
  },
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "overrides": {
      "@types/minimatch": "3.0.5"
    }
  },
  "packageManager": "pnpm@10.10.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
