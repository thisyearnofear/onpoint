{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "title": "OnPoint Agent Overview",
  "tags": ["onpoint", "agent", "monitoring", "prometheus"],
  "description": "Agent operational metrics: action counters, latency percentiles, escrow balances, and proactive heartbeat task results. Auto-provisioned — deploys with the monitoring stack.",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "15s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "id": 1,
      "title": "Agent Up",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_up",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Actions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thousandsSep": ","
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(agent_actions_total)",
          "legendFormat": "All actions",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Action Types Tracked",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(count by (type)(agent_actions_total))",
          "legendFormat": "Types",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Succeeded Actions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short",
          "thousandsSep": ","
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(agent_actions_total{status=\"succeeded\"})",
          "legendFormat": "Succeeded",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Actions by Type and Status",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "attempted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#6d6d6d" } }] },
          { "matcher": { "id": "byName", "options": "succeeded" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#73bf69" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f2495c" } }] }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "showValue": "auto",
        "stacking": "normal",
        "legend": {
          "showLegend": true,
          "displayMode": "table",
          "placement": "right",
          "calcs": ["sum"]
        },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(agent_actions_total) by (type, status)",
          "legendFormat": "{{type}} - {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Actions Summary",
      "type": "table",
      "gridPos": { "h": 10, "w": 4, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false,
            "minWidth": 0
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text",
                  "mode": "color-text"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "footer": {
          "show": true,
          "enablePagination": false,
          "fields": "",
          "reducer": ["sum"],
          "countRows": false
        },
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "showTypeIcons": false,
        "showHeader": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(sum(agent_actions_total) by (type, status))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{type}} - {{status}}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "seriesToRows",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "__name__": true, "instance": true, "__value__": true },
            "indexByName": { "Time": 0, "type": 1, "status": 2, "Value": 3 },
            "renameByName": { "Value": "Count" }
          }
        }
      ]
    },
    {
      "id": 7,
      "title": "Latency p50 by Action Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "hideFrom": { "graph": false, "legend": false, "tooltip": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["last", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_action_latency{quantile=\"0.5\"}",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Latency p99 by Action Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "hideFrom": { "graph": false, "legend": false, "tooltip": false },
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 3,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "ms"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "mint" },
            "properties": [{ "id": "custom.lineWidth", "value": 3 }]
          },
          {
            "matcher": { "id": "byName", "options": "purchase" },
            "properties": [{ "id": "custom.lineWidth", "value": 3 }]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": ["last", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_action_latency{quantile=\"0.99\"}",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Sample Count by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "hideFrom": { "graph": false, "legend": false, "tooltip": false },
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "pointSize": 3,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["last", "max"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_action_latency_count",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Escrow Balances",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 4, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#f2495c", "value": null },
              { "color": "#ff9830", "value": 1 },
              { "color": "#73bf69", "value": 5 }
            ]
          },
          "unit": "cUSD",
          "decimals": 2,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_escrow_balance / 1e18",
          "legendFormat": "{{user_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Escrow by User",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 4, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "semi-dark-red", "value": null },
              { "color": "semi-dark-yellow", "value": 1 },
              { "color": "semi-dark-green", "value": 5 }
            ]
          },
          "unit": "cUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false,
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(agent_escrow_balance) by (user_id) / 1e18",
          "legendFormat": "{{user_id}}",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "seriesToRows",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "job": true, "__name__": true, "instance": true },
            "indexByName": { "user_id": 0, "Value": 1 },
            "renameByName": { "Value": "Balance" }
          }
        }
      ]
    },
    {
      "id": 12,
      "title": "Proactive Heartbeat Tasks",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "none",
          "mappings": []
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "retryable_suggestions" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794f2" } }] },
          { "matcher": { "id": "byName", "options": "maxed_out_suggestions" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#f2495c" } }] },
          { "matcher": { "id": "byName", "options": "pruned_suggestions" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#ff9830" } }] },
          { "matcher": { "id": "byName", "options": "stale_approvals_alerted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#e0752d" } }] }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "groupWidth": 0.7,
        "barWidth": 0.85,
        "showValue": "auto",
        "stacking": "none",
        "legend": {
          "showLegend": true,
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_heartbeat_proactive",
          "legendFormat": "{{task}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Heartbeat Summary",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "count(agent_heartbeat_proactive > 0)",
          "legendFormat": "Active tasks",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "title": "Stale Approvals",
      "type": "stat",
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 30 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "semi-dark-yellow", "value": 1 },
              { "color": "semi-dark-red", "value": 5 }
            ]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "agent_heartbeat_proactive{task=\"stale_approvals_alerted\"}",
          "legendFormat": "Stale alerts",
          "refId": "A"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "OnPoint Prometheus", "value": "OnPoint Prometheus" },
        "hide": 1,
        "label": "Data Source",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "links": [
    {
      "title": "Prometheus Targets",
      "type": "link",
      "url": "http://localhost:9090/targets",
      "targetBlank": true
    },
    {
      "title": "Agent Dashboard",
      "type": "link",
      "url": "http://localhost:48751/api/status/dashboard",
      "targetBlank": true
    },
    {
      "title": "Metrics Raw",
      "type": "link",
      "url": "http://localhost:48751/api/agent/metrics",
      "targetBlank": true
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
