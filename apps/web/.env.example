# AI API Keys (at least one required)
REPLICATE_API_TOKEN=your_replicate_api_token_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
VENICE_API_KEY=your_venice_api_key_here

# WalletConnect Project ID (required for wallet connections)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Worldcoin App ID (required for Worldcoin integration)
NEXT_PUBLIC_WORLDCOIN_APP_ID=your_worldcoin_app_id_here

# Blockchain Configuration
ZETA_RPC_URL=https://zetachain-evm.blockpi.network/v1/rpc/public
CELO_ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Agent Signing (required for on-chain operations)
# Private key for the agent wallet - used for NFT minting, purchases, tips
# ⚠️ NEVER commit real private keys to version control
AGENT_PRIVATE_KEY=0xYourAgentPrivateKeyHere

# Smart Contract Addresses (Celo Mainnet)
NEXT_PUBLIC_ONPOINT_NFT_CONTRACT=0xdb65806c994C3f55079a6136a8E0886CbB2B64B1
NEXT_PUBLIC_PLATFORM_WALLET=0x05f012C12123D69E8324A251ae7D15A92C4549c1

# IPFS Configuration (Pinata/Lighthouse)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_here
LIGHTHOUSE_API_KEY=your_lighthouse_api_key_here

# Agent Store Persistence (Redis via Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# Optional: Memory Protocol API
NEXT_PUBLIC_MEMORY_API_KEY=your_memory_api_key_here