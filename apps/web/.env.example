# ============================================
# AI API Keys (at least one required)
# ============================================
VENICE_API_KEY=your_venice_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ============================================
# Auth0 — Token Vault & Authentication
# Get these from your Auth0 Dashboard: https://manage.auth0.com/
# ============================================
AUTH0_SECRET=<generate-with-openssl-rand-hex-32>
AUTH0_BASE_URL=http://localhost:3000
AUTH0_ISSUER_BASE_URL=https://<your-tenant>.auth0.com
AUTH0_DOMAIN=<your-tenant>.auth0.com
AUTH0_CLIENT_ID=<your-client-id>
AUTH0_CLIENT_SECRET=<your-client-secret>
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# Auth0 Management API (optional — required for revoking connections)
# Create a Machine-to-Machine app with "read:users" and "update:users" scopes
AUTH0_MANAGEMENT_API_TOKEN=your_management_api_token_here

# ============================================
# Redis — State Persistence & Rate Limiting
# Get a free instance at: https://upstash.com
# ============================================
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# ============================================
# Blockchain & Wallet
# ============================================
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here
NEXT_PUBLIC_ONPOINT_NFT_CONTRACT=0x8e0a3BcF07Ec8133408A3837DD2DCe398A42f576
AGENT_PRIVATE_KEY=0xYourAgentPrivateKeyHere
# Optional backend-only OWS vault path. The web app must not depend on OWS.
OWS_VAULT_PATH=/tmp/.ows/wallets
ZETA_RPC_URL=https://zetachain-evm.blockpi.network/v1/rpc/public

# ============================================
# IPFS / Decentralized Storage
# ============================================
LIGHTHOUSE_API_KEY=your_lighthouse_api_key_here
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_here

# ============================================
# M-Pesa Daraja API — STK Push auto-payment
# Get credentials at: https://developer.safaricom.co.ke/
# Sandbox (default): DARAJA_SANDBOX=true
# Set DARAJA_SANDBOX=false for production
# ============================================
DARAJA_CONSUMER_KEY=your_consumer_key_here
DARAJA_CONSUMER_SECRET=your_consumer_secret_here
DARAJA_PASSKEY=your_passkey_here
DARAJA_BUSINESS_SHORTCODE=174379
DARAJA_SANDBOX=true
# Base URL for the STK callback (publicly reachable).
# Defaults to APP_BASE_URL > NEXT_PUBLIC_AGENT_API_URL > localhost:3000
# DARAJA_CALLBACK_BASE_URL=https://your-domain.com

# ============================================
# WhatsApp Business API — Send order receipts to customers via WhatsApp
# Set WA_ACCESS_TOKEN and WA_PHONE_NUMBER_ID to enable automatic receipt
# delivery after order completion. Same credentials as the agent-server.
# Get these from Meta Developer Portal → WhatsApp → Business Account.
# ============================================
WA_ACCESS_TOKEN=your_whatsapp_access_token_here
WA_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here

# ============================================
# Web Push (VAPID) — Push notifications for order tracking even when the page is closed
# Generate keys with: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log('NEXT_PUBLIC_VAPID_PUBLIC_KEY='+k.publicKey);console.log('VAPID_PRIVATE_KEY='+k.privateKey)"
# ============================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# ============================================
# External Services
# ============================================
NEXT_PUBLIC_WORLDCOIN_APP_ID=your_worldcoin_app_id_here
NEXT_PUBLIC_AGENT_API_URL=https://api.onpoint.famile.xyz
NEXT_PUBLIC_MEMORY_API_KEY=your_memory_api_key_here
EXTERNAL_AGENT_URL=http://localhost:8000
TINYFISH_API_KEY=your_tinyfish_api_key_here
SESSION_SECRET=your_32_character_secret_key_here

# ============================================
# 0G Compute Router (0G Bridge Buildathon Wave 1)
# ============================================
# Public flag so the client knows the 0G option is wired in.
# The actual API key stays on the Hetzner API server (apps/api/.env).
# If NEXT_PUBLIC_ZERO_G_ENABLED is "true" the 0G provider and live-
# session factory are surfaced on the AI selection cards.
NEXT_PUBLIC_ZERO_G_ENABLED=false
# The 0G model name to advertise to the client (purely UI metadata)
NEXT_PUBLIC_ZERO_G_MODEL=qwen3-vl-30b

# ============================================
# Etherfuse FX API — Fiat onramp (MXN / USD / EUR → USDC on Base / Celo)
# Sandbox keys: https://devnet.etherfuse.com/ramp/manage-api
# Production keys: https://app.etherfuse.com/ramp/manage-api
# Get the webhook secret from the same dashboard after creating a webhook
# pointing at https://api.<your-domain>/api/webhooks/etherfuse (the Express server, not the Next.js app)
# ============================================
ETHERFUSE_API_KEY=
ETHERFUSE_ENV=sandbox
# Optional: override the API base URL
# ETHERFUSE_BASE_URL=https://api.sand.etherfuse.com
# Default chain for onramp settlement (base | celo | ethereum | polygon)
ETHERFUSE_DEFAULT_CHAIN=base
# Default fiat currency (MXN pairs with Bitso / SPEI / OXXO)
ETHERFUSE_DEFAULT_FIAT=MXN
# Webhook signing secret — required to verify inbound webhooks
ETHERFUSE_WEBHOOK_SECRET=

# ============================================
# Web Data UNLOCKED — Market intelligence providers
# Bright Data runs in packages/agent-web-bridge; partner keys are optional.
# Missing partner keys return "ready" states instead of failing the Intel page.
# ============================================
BRIGHTDATA_API_KEY=your_brightdata_api_key_here
BRIGHTDATA_SERP_ZONE=serp_api1
AIML_API_KEY=your_aiml_api_key_here
AIML_API_BASE_URL=https://api.aimlapi.com/v1
AIML_API_MODEL=gpt-4o-mini
COGNEE_API_URL=https://tenant-9ea9c754-b777-4529-bfb7-d5c550b873dc.aws.cognee.ai
COGNEE_TENANT_ID=9ea9c754-b777-4529-bfb7-d5c550b873dc
COGNEE_API_KEY=your_cognee_api_key_here
TRIGGERWARE_API_URL=https://api.triggerware.com
TRIGGERWARE_API_KEY=your_triggerware_api_key_here
TRIGGERWARE_TRIGGER_NAME=onpoint_retail_product_gap

# ============================================
# KarmaGAP — Grant & Project Management API
# Get API key at: https://gap.karmahq.xyz/
# Docs: https://docs.gap.karmahq.xyz/
# ============================================
KARMA_GAP_API_KEY=your_karma_gap_api_key_here
KARMA_GAP_BASE_URL=https://gapapi.karmahq.xyz/v2

# ============================================
# Production web-to-Hetzner proxy
# Required on Netlify for AI proxy and agent routes.
# ============================================
AGENT_API_URL=https://api.onpoint.famile.xyz
SERVICE_API_KEY=match_hetzner_service_api_key

# ============================================
# Stripe — Card Payments (optional, enables non-crypto checkout)
# Get keys at: https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_PREMIUM_PRICE_ID=price_your_premium_price_id
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# Error Monitoring (optional, enables Sentry)
# Get DSN at: https://sentry.io
# ============================================
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# ============================================
# Cloudflare R2 — Admin photo uploads & image serving
# Set this to your R2 public bucket URL (e.g., https://pub-xxxx.r2.dev)
# Uses the same R2_PUBLIC_URL as the Hetzner API server for admin photo viewing
# ============================================
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-bucket.r2.dev

# ============================================
# Analytics (optional, enables PostHog)
# Get keys at: https://posthog.com
# ============================================
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Email (optional, enables welcome + re-engagement emails)
# Get API key at: https://resend.com
# ============================================
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=OnPoint <noreply@yourdomain.com>

# Admin email for automated weekly retention digest
# The digest is sent every 7 days from the Hetzner worker via /api/cron/retention-digest
ADMIN_EMAIL=admin@yourdomain.com
