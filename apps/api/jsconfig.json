{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "resolveJsonModule": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2022",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["lib/**/*", "routes/**/*", "middleware/**/*", "server.js", "worker.js", "signer.js"],
  "exclude": ["node_modules/**", "*.test.js"]
}
