# OnPoint API Environment Variables (Production)
# Copy to .env.production on server

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Etherfuse FX API — fiat onramp (see apps/web/.env.example for full docs)
ETHERFUSE_API_KEY=
ETHERFUSE_ENV=sandbox
ETHERFUSE_DEFAULT_CHAIN=base
ETHERFUSE_DEFAULT_FIAT=MXN
ETHERFUSE_WEBHOOK_SECRET=

# Bridge Configuration (internal HTTP call)
BRIDGE_URL=http://localhost:48752

# API Server Config
PORT=48751
NODE_ENV=production

# Authentication (comma-separated user IDs)
PREMIUM_USERS=

# AI Provider Keys (required for /api/ai/* routes)
VENICE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# 0G Compute Router (0G Bridge Buildathon Wave 1)
# Bearer key from pc.0g.ai → API keys. NEVER commit a real key.
# The Router is OpenAI Chat Completions compatible:
#   https://router-api.0g.ai/v1
ZERO_G_API_KEY=
# Default model — verified vision-capable on the live catalog
ZERO_G_MODEL=qwen3-vl-30b
# Override the chat model for persona / non-vision calls
ZERO_G_CHAT_MODEL=qwen3-vl-30b
# Override the base URL for testnet routing
# ZERO_G_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
# Hard timeout in ms (default 20000)
# ZERO_G_TIMEOUT_MS=20000

# Qwen Cloud (DashScope) — Qwen Cloud Hackathon, Track 4: Autopilot Agent
# Bearer key from https://home.qwencloud.com/ → API Key Management. NEVER commit.
# The API is OpenAI Chat Completions compatible:
#   https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# (use the -intl endpoint; the China endpoint dashscope.aliyuncs.com rejects
#  keys created on the international platform.)
DASHSCOPE_API_KEY=
# Default vision model — cheapest on the Qwen Cloud catalog
QWEN_CLOUD_VISION_MODEL=qwen3-vl-flash
# Default chat/text model — cheapest text model
QWEN_CLOUD_CHAT_MODEL=qwen3.6-flash
# Override the base URL (rare; defaults to the intl endpoint above)
# QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Hard timeout in ms (default 20000)
# QWEN_CLOUD_TIMEOUT_MS=20000
# ── Spend controls ──
# Daily budget in USD. When the in-memory counter hits this, calls throw.
# Default: 1.00. Set to 0 to disable the budget gate.
QWEN_CLOUD_DAILY_BUDGET_USD=1.00
# Kill switch — when 1, every Qwen Cloud call throws immediately.
QWEN_CLOUD_KILL_SWITCH=0

# Alibaba Cloud OSS — try-on artifact mirror
# Qwen Cloud Hackathon, Track 4: Autopilot Agent.
# This is the Proof of Alibaba Cloud Deployment required by the hackathon.
# Recommended region: oss-us-west-1 (international) to avoid China
# real-name verification. Create the bucket at:
#   https://oss.console.alibabacloud.com/
# AccessKey ID + Secret from:
#   https://ram.console.alibabacloud.com/manage/ak
ALIBABA_OSS_ACCESS_KEY_ID=
ALIBABA_OSS_ACCESS_KEY_SECRET=
ALIBABA_OSS_BUCKET=
ALIBABA_OSS_REGION=oss-us-west-1
# Optional: public CDN URL for reads (if you front the bucket with a CDN)
# ALIBABA_OSS_PUBLIC_URL=https://cdn.example.com
# Optional: override the endpoint (e.g. for an internal endpoint)
# ALIBABA_OSS_ENDPOINT=

# Signer Configuration (ADR 0001 Phase 4)
# When set, all signing is delegated to the isolated signer process.
# AGENT_PRIVATE_KEY is no longer needed in this process when SIGNER_URL is set.
SIGNER_URL=http://127.0.0.1:48753
# SIGNER_API_KEY= (required — must match the signer's value)

# Magic embedded wallet — server secret only (Express / TEE). Never commit or expose to web.
# Publishable key lives in apps/web: NEXT_PUBLIC_MAGIC_PUBLISHABLE_KEY
MAGIC_SECRET_KEY=

# Optional: Override for external services
# EXTERNAL_AGENT_URL=http://localhost:48752

# KarmaGAP — Grant & Project Management API
# Get API key at: https://gap.karmahq.xyz/
KARMA_GAP_API_KEY=
KARMA_GAP_BASE_URL=https://gapapi.karmahq.xyz/v2

# Web app base URL (used for share links, webhooks, etc.)
# Defaults to https://beonpoint.netlify.app if not set
WEB_BASE_URL=https://beonpoint.netlify.app

# x402 Facilitator (Celo gasless payments)
# Defaults to https://api.x402.celo.org if not set
X402_FACILITATOR_URL=https://api.x402.celo.org

# Replicate API (IDM-VTON physical try-on + RMBG background removal for look collages)
REPLICATE_API_TOKEN=
# REPLICATE_API_BASE_URL=https://api.replicate.com/v1

# Venice AI base URL (override for testnet/proxy)
# VENICE_BASE_URL=https://api.venice.ai/api/v1
