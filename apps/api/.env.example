# OnPoint API Environment Variables (Production)
# Copy to .env.production on server

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Etherfuse FX API — fiat onramp (see apps/web/.env.example for full docs)
ETHERFUSE_API_KEY=
ETHERFUSE_ENV=sandbox
ETHERFUSE_DEFAULT_CHAIN=base
ETHERFUSE_DEFAULT_FIAT=MXN
ETHERFUSE_WEBHOOK_SECRET=

# Bridge Configuration (internal HTTP call)
BRIDGE_URL=http://localhost:48752

# API Server Config
PORT=48751
NODE_ENV=production

# Authentication (comma-separated user IDs)
PREMIUM_USERS=

# AI Provider Keys (required for /api/ai/* routes)
VENICE_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
# 0G Compute Router (0G Bridge Buildathon Wave 1)
# Bearer key from pc.0g.ai → API keys. NEVER commit a real key.
# The Router is OpenAI Chat Completions compatible:
#   https://router-api.0g.ai/v1
ZERO_G_API_KEY=
# Default model — verified vision-capable on the live catalog
ZERO_G_MODEL=qwen3-vl-30b
# Override the chat model for persona / non-vision calls
ZERO_G_CHAT_MODEL=qwen3-vl-30b
# Override the base URL for testnet routing
# ZERO_G_BASE_URL=https://router-api-testnet.integratenetwork.work/v1
# Hard timeout in ms (default 20000)
# ZERO_G_TIMEOUT_MS=20000

# Signer Configuration (ADR 0001 Phase 4)
# When set, all signing is delegated to the isolated signer process.
# AGENT_PRIVATE_KEY is no longer needed in this process when SIGNER_URL is set.
SIGNER_URL=http://127.0.0.1:48753
# SIGNER_API_KEY= (required — must match the signer's value)

# Optional: Override for external services
# EXTERNAL_AGENT_URL=http://localhost:48752
