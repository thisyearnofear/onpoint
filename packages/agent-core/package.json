{
  "name": "@repo/agent-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@repo/blockchain-client": "workspace:*",
    "@repo/ipfs-client": "workspace:*",
    "@upstash/redis": "1.37.0",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "@open-wallet-standard/core": "*",
    "@tetherto/wdk": "*",
    "@tetherto/wdk-wallet-evm": "*"
  },
  "peerDependenciesMeta": {
    "@open-wallet-standard/core": {
      "optional": true
    },
    "@tetherto/wdk": {
      "optional": true
    },
    "@tetherto/wdk-wallet-evm": {
      "optional": true
    }
  }
}
