{
  "name": "@repo/agent-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./agent-api": {
      "types": "./src/agent-api.ts",
      "import": "./src/agent-api.ts"
    },
    "./agent-controls": {
      "types": "./src/agent-controls.ts",
      "import": "./src/agent-controls.ts"
    },
    "./agent-registry": {
      "types": "./src/agent-registry.ts",
      "import": "./src/agent-registry.ts"
    },
    "./agent-reputation": {
      "types": "./src/agent-reputation.ts",
      "import": "./src/agent-reputation.ts"
    },
    "./agent-store": {
      "types": "./src/agent-store.ts",
      "import": "./src/agent-store.ts"
    },
    "./agent-wallet": {
      "types": "./src/agent-wallet.ts",
      "import": "./src/agent-wallet.ts"
    },
    "./autonomous-executor": {
      "types": "./src/autonomous-executor.ts",
      "import": "./src/autonomous-executor.ts"
    },
    "./chains": {
      "types": "./src/chains.ts",
      "import": "./src/chains.ts"
    },
    "./commissions": {
      "types": "./src/commissions.ts",
      "import": "./src/commissions.ts"
    },
    "./erc20": {
      "types": "./src/erc20.ts",
      "import": "./src/erc20.ts"
    },
    "./escrow-service": {
      "types": "./src/escrow-service.ts",
      "import": "./src/escrow-service.ts"
    },
    "./fraud-detection": {
      "types": "./src/fraud-detection.ts",
      "import": "./src/fraud-detection.ts"
    },
    "./logger": {
      "types": "./src/logger.ts",
      "import": "./src/logger.ts"
    },
    "./persistent-state": {
      "types": "./src/persistent-state.ts",
      "import": "./src/persistent-state.ts"
    },
    "./redis-helpers": {
      "types": "./src/redis-helpers.ts",
      "import": "./src/redis-helpers.ts"
    },
    "./verifiable-agent-service": {
      "types": "./src/verifiable-agent-service.ts",
      "import": "./src/verifiable-agent-service.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@repo/blockchain-client": "workspace:*",
    "@repo/ipfs-client": "workspace:*",
    "@upstash/redis": "1.38.0",
    "viem": "^2.21.0"
  },
  "peerDependencies": {
    "@open-wallet-standard/core": "*",
    "@tetherto/wdk": "*",
    "@tetherto/wdk-wallet-evm": "*"
  },
  "peerDependenciesMeta": {
    "@open-wallet-standard/core": {
      "optional": true
    },
    "@tetherto/wdk": {
      "optional": true
    },
    "@tetherto/wdk-wallet-evm": {
      "optional": true
    }
  }
}
