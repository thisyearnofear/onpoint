# OnPoint Agent Web-Bridge Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Purch API Configuration (Tier 2 - Primary)
# ============================================
PURCH_API_URL=https://api.purch.xyz

# Optional: Wallet private key for x402 payment signing
# Format: 0x... (hex string)
# If not set, Purch will operate in demo mode
PURCH_WALLET_PRIVATE_KEY=

# Optional: API key (may be required for future auth)
PURCH_API_KEY=

# ============================================
# Browser Use Cloud (Tier 3 - Deep Browsing)
# ============================================
# Get your API key from https://browser-use.com/dashboard
BROWSER_USE_API_KEY=

# ============================================
# TinyFish (Tier 2.5 Search+Fetch / Tier 3 Agent fallback)
# ============================================
# Get your API key from https://agent.tinyfish.ai/api-keys
# Provides redundancy: if Browser Use is down, TinyFish Agent takes over
TINYFISH_API_KEY=

# Optional: Default Browser Context Profile id. When set, the agent reuses
# saved logged-in state for retailer runs (e.g. authenticated SSENSE/Farfetch).
# Per-user profile registry is a separate ADR scope.
# TINYFISH_DEFAULT_PROFILE_ID=

# Kill switch (ADR 0008 D5). Defaults to the async-polling path.
# Set to 0 to revert to the legacy blocking /v1/automation/run path —
# useful for one-flag rollback if the polling primitive misbehaves.
# TINYFISH_ASYNC=1

# ============================================
# Bright Data (Tier 2.5 SERP + Web Unlocker)
# ============================================
# Get your API key from https://brightdata.com/cp/api
# Used for structured Google Shopping search and product page extraction
BRIGHTDATA_API_KEY=

# SERP API zone name (default: serp_api)
BRIGHTDATA_SERP_ZONE=serp_api

# Web Unlocker zone name (default: web_unlocker)
BRIGHTDATA_UNLOCKER_ZONE=web_unlocker

# Optional: deterministic fixture mode for demos and offline judging
DEMO_MARKET_INTEL=0

# ============================================
# Server Configuration
# ============================================
HOST=127.0.0.1
PORT=8000

# Environment (development | production)
ENVIRONMENT=development

# ============================================
# Authentication
# ============================================
# Required in production. Clients must send:
#   Authorization: Bearer <BRIDGE_API_KEY>
# Generate with: openssl rand -hex 32
BRIDGE_API_KEY=

# Comma-separated allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000
