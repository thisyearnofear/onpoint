{
  "name": "@repo/etherfuse",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./quote": {
      "types": "./src/quote.ts",
      "import": "./src/quote.ts"
    },
    "./order": {
      "types": "./src/order.ts",
      "import": "./src/order.ts"
    },
    "./webhook": {
      "types": "./src/webhook.ts",
      "import": "./src/webhook.ts"
    },
    "./balances": {
      "types": "./src/balances.ts",
      "import": "./src/balances.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "migrate": "npx tsx scripts/migrate-topups.ts"
  },
  "dependencies": {
    "ioredis": "^5.6.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "5.9.2"
  }
}
