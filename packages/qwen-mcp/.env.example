# Qwen Cloud MCP Server — Environment Variables
# Copy to .env and fill in values

# DashScope (Qwen Cloud) API key — required
# Get from: https://home.qwencloud.com/ → API Key Management
DASHSCOPE_API_KEY=

# OnPoint API base URL — used by browse_curator_directory tool
# Defaults to https://api.onpoint.famile.xyz if not set
ONPOINT_API_BASE=https://api.onpoint.famile.xyz

# Qwen Cloud base URL (OpenAI-compatible endpoint)
# Use the -intl endpoint; the China endpoint rejects intl keys.
# Defaults to https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_CLOUD_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Vision model for analyze_african_textile tool
# Defaults to qwen3-vl-flash (cheapest on the catalog)
QWEN_CLOUD_VISION_MODEL=qwen3-vl-flash

# Kill switch — when 1, every Qwen Cloud call throws immediately
QWEN_CLOUD_KILL_SWITCH=0
