{
  "name": "@repo/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./migrate": {
      "types": "./src/migrate.ts",
      "import": "./src/migrate.ts",
      "require": "./dist/migrate.cjs",
      "default": "./dist/migrate.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit --project tsconfig.drizzle.json",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "drizzle-kit": "^0.30.0",
    "tsup": "8.5.1",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "drizzle-orm": "^0.40.0",
    "@neondatabase/serverless": "^1.0.0"
  }
}
