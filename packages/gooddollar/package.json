{
  "name": "@repo/gooddollar",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./addresses": {
      "types": "./src/addresses.ts",
      "import": "./src/addresses.ts"
    },
    "./abis": {
      "types": "./src/abis.ts",
      "import": "./src/abis.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./claim": {
      "types": "./src/claim.ts",
      "import": "./src/claim.ts"
    },
    "./streaming": {
      "types": "./src/streaming.ts",
      "import": "./src/streaming.ts"
    },
    "./balance": {
      "types": "./src/balance.ts",
      "import": "./src/balance.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/agent-core": "workspace:*",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "tsup": "8.5.1",
    "typescript": "5.9.2",
    "vitest": "^3.2.6"
  }
}
